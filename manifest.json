{
  "manifest_version": 3,
  "name": "ChatGPT TOC",
  "version": "2.1.0",
  "description": "Floating TOC for ChatGPT chats.",
  "host_permissions": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
