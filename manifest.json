{
  "manifest_version": 3,
  "name": "Web Browser ChatGPT TOC",
  "version": "2.1.0",
  "description": "A floating, searchable table of contents for ChatGPT conversations.",
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
